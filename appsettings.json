{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },

  "AllowedHosts": "*",

  // Database connection
  "ConnectionStrings": {
    "DefaultConnection": "Data Source=(localdb)\\MSSQLLocalDB;Initial Catalog=E-CommerceSystem-API;Integrated Security=True;TrustServerCertificate=True"
  },

  // JWT settings
  "Jwt": {
    "Key": "securekeySecurekey-SecuritySecureKeySecuritySecureKey", //MUST BE GREATER THAN 32 CHARACTERS
    "Issuer": "ECommerceAPI",
    "Audience": "ECommerceClient",
    "ExpiryMinutes": 60
  }

}
